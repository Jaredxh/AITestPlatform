# ========== 数据库 ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aitest
POSTGRES_PASSWORD=aitest123
POSTGRES_DB=aitest_platform

# ========== 后端 ==========
SECRET_KEY=change-me-in-production-use-a-long-random-string

# Fernet 对称加密 key —— 用于在 DB 里加密 LLM api_key / UI 自动化登录凭据 /
# 测试物料 secret / Skill 凭据等"敏感字段"。
#
# ⚠️ 这把 key 一旦换掉，旧库里所有已加密字段会**永久解不开**（必须清空重填），
#    所以一个部署点定下来后**别再动**。
#
# 下面这把是开箱即用的默认 key（与 backend/app/config.py 里的 fallback 同步），
# 内网测试平台 / 个人开发环境**直接用就行**——`cp .env.example .env` 后无需改动。
#
# ⛔ 真要面对公网 / 真实生产：这把 key 谁拿到源码都能解你 DB，请用下面这条
# 命令生成自己的独立 key 替换：
#   docker run --rm python:3.11-slim python -c \
#     "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPT_KEY=sTOsMs0VqznVBvb3aBWQzqs3UctMQllS9Rf5Ii-JARc=
DEBUG=true
BACKEND_HOST=0.0.0.0
# 宿主机映射端口（用户访问后端走这个端口）
# 容器内 uvicorn 始终监听 8000，无需修改容器内端口
# 服务器上 8000 被占用时改成其它，例如 7008
BACKEND_PORT=8000

# ── 前端访问端口 ──
# 浏览器访问平台的端口（默认 80，HTTP 默认端口，URL 里不需要写）
# 容器内 nginx 始终监听 80，无需修改容器内端口
# 服务器 80 被占用 / 上游有 Caddy/Nginx 反代时改成 8080 等
# 改了之后访问地址变成 http://your-host:<新端口>
FRONTEND_PORT=80

# ========== Docker「构建」阶段网络（VPN 打不开别慌，看下面两行） ==========
#
# 1）为什么「电脑上 VPN 开着」docker build 仍访问不了 deb.debian.org？
# Docker Desktop（尤其 macOS）：镜像是在 **Linux 虚拟机里**编的，出站流量不等于
# 你 Mac 菜单栏 VPN 的那一个网络栈（常见 split tunnel / 虚拟机直连外网）。
# docker-compose.vpn.yml 只作用于**运行中**容器，也不等于 build 走路由表。
#
# 2）办法 A — 宿主起 HTTP 代理（mitmproxy 等），构建走代理：
# HTTP_PROXY=http://host.docker.internal:8118
# HTTPS_PROXY=http://host.docker.internal:8118
# NO_PROXY=localhost,127.0.0.1,host.docker.internal,db,backend,frontend
#
# 3）办法 B — 不换代理，改用 Debian apt 镜像站（仅此 hostname，不要写 http://）：
# APT_MIRROR_HOST=mirrors.aliyun.com
#
# 任选其一或多管齐下；不写则 Dockerfile 仍会启用 apt 多重重试（对全员无害）。

# ========== 初始管理员（首次部署自动创建） ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@aitest.local

# ========== 前端 ==========
# 仅本地 vite dev 模式 (npm run dev) 用；生产 nginx 反代不依赖此变量
# 若改了 BACKEND_PORT，本地开发时这里也要同步改成 http://localhost:<新端口>
VITE_API_BASE_URL=http://localhost:8000

# ========== LLM（可选，后续在平台内配置） ==========
# DEFAULT_LLM_API_KEY=sk-xxx
# DEFAULT_LLM_BASE_URL=https://api.deepseek.com
# DEFAULT_LLM_MODEL=deepseek-chat

# ========== 二期 UI 自动化（Task 11.3） ==========
# 物料 secret 加密：复用一期 ENCRYPT_KEY，不需要单独密钥。
# 生成命令（首次部署）：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：ENCRYPT_KEY 一旦换掉，已经加密的 secret 物料 / 凭据将无法解密。
#
# UI state 文件（BrowserContext storage_state，含登录 cookie）持久化目录
# 默认 uploads/ui_state；生产已通过 docker-compose 挂 named volume + chmod 700
# UI_STATE_DIR=uploads/ui_state
#
# 物料文件根目录（默认 uploads/test-data）
# TEST_DATA_UPLOAD_DIR=uploads/test-data
# 单个物料 file 上限（字节），默认 50MB
# TEST_DATA_MAX_FILE_SIZE=52428800
#
# Snapshot 裁剪上限（snapshot_clipper 真的会读这两个；调高让 LLM 看到更多
# accessibility tree，调低省 token）
UI_SNAPSHOT_MAX_CHARS=3000
UI_SNAPSHOT_DIFF_CONTEXT=2

# ========== 三期 Skill 体系（Task 12 / OpenClaw 协议） ==========
# Skill 包内置工具 ``http_get_json`` / ``http_post_json`` 的出口代理（可选）。
# 用于"被测系统在公司内网，宿主机 VPN 通、容器直连不通"场景：把代理跑在宿主机
# (mitmproxy / tinyproxy / pproxy)，让技能包请求经它出口命中 VPN 隧道。
# 优先级：SKILL_HTTP_PROXY → UI_HTTP_LOGIN_PROXY → 系统 HTTP_PROXY；
# 全空 = 直连（默认）。例：``http://host.docker.internal:8118``。
# SKILL_HTTP_PROXY=

# ========== 清理 cron（Task 11.2） ==========
# 周期清理任务间隔（小时）；0 = 关闭，仅保留 admin 手动 API
CLEANUP_INTERVAL_HOURS=24
# 启动时是否立刻跑一次（默认 false，避免重启风暴）
CLEANUP_RUN_ON_STARTUP=false
# UI 自动化媒体（视频 / 截图 / trace / step screenshot）保留天数
UI_MEDIA_RETENTION_DAYS=30
# 孤立 storage_state 文件保留天数（DB 中无对应 env 的）
UI_STATE_RETENTION_DAYS=7
# step snapshot_before/after + tool_calls 大字段保留天数（仅清空字段，行还在）
UI_SNAPSHOT_RETENTION_DAYS=7
# 测试物料 file 类型的孤立物理文件保留天数
TEST_DATA_FILE_RETENTION_DAYS=90
# 测试物料审计日志保留天数（预留，审计表上线后启用）
TEST_DATA_AUDIT_RETENTION_DAYS=180

# ── 技能脚本子进程资源闸（``run_skill_script``）───────────────────────────
# 不写时用代码默认值（足够跑 npm/npx install 这类 OpenClaw 风格安装命令）。
# 开放这些旋钮的目的：
#   - 大型脚本（如批量诊断 100 个 mid）总超时 → 调大 SKILL_SCRIPT_TIMEOUT_S；
#   - 容器只有 1 GB 内存 → 调小 RLIMIT_AS_MB 与 NODE_MAX_OLD_SPACE_MB；
#   - 安全敏感场景 → 全部调小，宁可拒掉也别撑爆容器。
# wall-clock 35s → 90s 起：低于 60s 时 ``npx install`` 与 ``pip install`` 必失败。
#SKILL_SCRIPT_TIMEOUT_S=90
#SKILL_SCRIPT_RLIMIT_CPU_S=60
#SKILL_SCRIPT_RLIMIT_AS_MB=2048
#SKILL_SCRIPT_RLIMIT_FSIZE_MB=256
#SKILL_SCRIPT_NODE_MAX_OLD_SPACE_MB=1024

# ========== 镜像源（仅 docker-compose.prod.yml 使用） ==========
# 这一段仅当用 docker-compose.prod.yml（拉预构建镜像部署）时需要。
# docker-compose.yml（本地 build）不读这些变量，可以忽略。
#
# 【开箱即用】下面 3 行已取消注释 → 直接 cp .env.example .env 即可拉到
# 本仓库作者构建的 GHCR public 镜像，无需 docker login。
IMAGE_REGISTRY=ghcr.io
IMAGE_NAMESPACE=jaredxh                            # 作者 GitHub 用户名（fork 后改成自己的）
IMAGE_TAG=latest                                   # 跟 main 最新；生产建议钉 v1.2.3
#
# ── 提速方案 A：GHCR 国内反代（不需要任何账号，匿名 pull，秒级） ──
# 国内服务器拉 ghcr.io 慢（无 CDN）。把上面 IMAGE_REGISTRY 改成下面任一即可：
#   IMAGE_REGISTRY=ghcr.nju.edu.cn               # 南京大学（推荐，最稳定）
#   IMAGE_REGISTRY=ghcr.dockerproxy.com          # dockerproxy 反代
#   IMAGE_REGISTRY=ghcr.1panel.live              # 1Panel 反代
# 注：反代只代理 GHCR public 镜像，IMAGE_NAMESPACE 仍写作者用户名（jaredxh）
#
# ── 提速方案 B：fork 本仓库 + 配自己的阿里云 ACR（国内秒级，最一劳永逸） ──
# 1) Fork 本仓库到自己 GitHub 账号
# 2) 开通阿里云 ACR 个人版（免费）拿到独立域名 crpi-xxxx.<region>.personal.cr.aliyuncs.com
# 3) 在自己 fork 仓库 Settings → Secrets 加 4 个：ACR_REGISTRY / ACR_NAMESPACE / ACR_USERNAME / ACR_PASSWORD
# 4) 触发自己仓库的 Actions 构建（push 一次空 commit 即可），workflow 自动同步到 ACR
# 5) 服务器 docker login + 把上面 3 行改成自己的：
#    IMAGE_REGISTRY=crpi-xxxx.cn-xxx.personal.cr.aliyuncs.com
#    IMAGE_NAMESPACE=<your-acr-namespace>
#    IMAGE_TAG=latest
# 完整教程：docs/DEPLOYMENT_GHCR.md §阿里云 ACR 同步
