# ========== 数据库 ==========
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=aitest
POSTGRES_PASSWORD=aitest123
POSTGRES_DB=aitest_platform

# ========== 后端 ==========
SECRET_KEY=change-me-in-production-use-a-long-random-string
ENCRYPT_KEY=
DEBUG=true
BACKEND_HOST=0.0.0.0
# 宿主机映射端口（用户访问后端走这个端口）
# 容器内 uvicorn 始终监听 8000，无需修改容器内端口
# 服务器上 8000 被占用时改成其它，例如 7008
BACKEND_PORT=8000

# ========== 初始管理员（首次部署自动创建） ==========
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@aitest.local

# ========== 前端 ==========
# 仅本地 vite dev 模式 (npm run dev) 用；生产 nginx 反代不依赖此变量
# 若改了 BACKEND_PORT，本地开发时这里也要同步改成 http://localhost:<新端口>
VITE_API_BASE_URL=http://localhost:8000

# ========== LLM（可选，后续在平台内配置） ==========
# DEFAULT_LLM_API_KEY=sk-xxx
# DEFAULT_LLM_BASE_URL=https://api.deepseek.com
# DEFAULT_LLM_MODEL=deepseek-chat

# ========== 二期 UI 自动化（Task 11.3） ==========
# 物料 secret 加密：复用一期 ENCRYPT_KEY，不需要单独密钥。
# 生成命令（首次部署）：
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：ENCRYPT_KEY 一旦换掉，已经加密的 secret 物料 / 凭据将无法解密。
#
# UI state 文件（BrowserContext storage_state，含登录 cookie）持久化目录
# 默认 uploads/ui_state；生产已通过 docker-compose 挂 named volume + chmod 700
# UI_STATE_DIR=uploads/ui_state
#
# 物料文件根目录（默认 uploads/test-data）
# TEST_DATA_UPLOAD_DIR=uploads/test-data
# 单个物料 file 上限（字节），默认 50MB
# TEST_DATA_MAX_FILE_SIZE=52428800
#
# Snapshot 裁剪上限（snapshot_clipper 真的会读这两个；调高让 LLM 看到更多
# accessibility tree，调低省 token）
UI_SNAPSHOT_MAX_CHARS=3000
UI_SNAPSHOT_DIFF_CONTEXT=2

# ========== 清理 cron（Task 11.2） ==========
# 周期清理任务间隔（小时）；0 = 关闭，仅保留 admin 手动 API
CLEANUP_INTERVAL_HOURS=24
# 启动时是否立刻跑一次（默认 false，避免重启风暴）
CLEANUP_RUN_ON_STARTUP=false
# UI 自动化媒体（视频 / 截图 / trace / step screenshot）保留天数
UI_MEDIA_RETENTION_DAYS=30
# 孤立 storage_state 文件保留天数（DB 中无对应 env 的）
UI_STATE_RETENTION_DAYS=7
# step snapshot_before/after + tool_calls 大字段保留天数（仅清空字段，行还在）
UI_SNAPSHOT_RETENTION_DAYS=7
# 测试物料 file 类型的孤立物理文件保留天数
TEST_DATA_FILE_RETENTION_DAYS=90
# 测试物料审计日志保留天数（预留，审计表上线后启用）
TEST_DATA_AUDIT_RETENTION_DAYS=180
